# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=AIDOC
ENVIRONMENT=development
DEFAULT_TENANT_ID=default

# ─── Postgres ───────────────────────────────────────────────────────────────
# En docker-compose esto lo sobreescribe el service. Para correr local fuera de
# docker, apuntá a localhost.
DATABASE_URL=postgresql+asyncpg://aidoc:aidoc@localhost:5432/aidoc

# ─── Redis (cola de indexado async) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant (vector store) ────────────────────────────────────────────────────
# Con docker compose usá el hostname del servicio (http://qdrant:6333); el backend
# corre DENTRO de un contenedor y "localhost" no llega al Qdrant bundleado.
# Para usar el Qdrant de PCAI: https://qdrant.ai-application.ciisagl.local:443
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=aidoc_documents
QDRANT_API_KEY=

# ─── Object storage (S3 / MinIO) ──────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=aidoc
S3_SECRET_KEY=aidoc-secret
S3_BUCKET=aidoc-documents
S3_REGION=us-east-1

# ─── LLM (NVIDIA NIM en HPE PCAI) ─────────────────────────────────────────────
LLM_URL=https://llm-qwen3-30b-042026.project-pyxiia-proyectos.serving.ai-application.ciisagl.local/v1
LLM_API_KEY=placeholder-llm-key
LLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507-FP8
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDINGS_URL=https://emb-qwen3-06b.project-user-jmartinez.serving.ai-application.ciisagl.local/v1
EMBEDDINGS_API_KEY=placeholder-emb-key
EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBED_DIMENSIONS=1024

# ─── Ingesta / RAG ────────────────────────────────────────────────────────────
CHUNK_SIZE=2000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=8
BATCH_WORKERS=4

# ─── SSL (certs self-signed en PCAI) ──────────────────────────────────────────
VERIFY_SSL=false

# ─── Auth (OBLIGATORIO para poder iniciar sesión) ─────────────────────────────
# SECRET_KEY firma los JWT de sesión de la app: mínimo 32 chars aleatorios.
# Generá uno con:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esto-por-32-chars-aleatorios-minimo
# El super-admin se crea automáticamente al arrancar si no existe. Con él entrás
# y creás las organizaciones y sus usuarios (POST /api/auth/organizations).
# Usá un dominio de email real (los .local son rechazados por el validador).
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=cambia-este-password
ACCESS_TOKEN_EXPIRE_MINUTES=720
